{
  "name": "netflow-electron",
  "version": "1.0.0",
  "description": "Real-time NetFlow Traffic Monitor — Windows host to destination IP/prefix",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "id.syahrulramadhan.netflow-electron",
    "productName": "NetFlow Monitor",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/syahrullrmdhn/netflow-electron.git"
  },
  "publish": {
    "provider": "github",
    "owner": "syahrullrmdhn",
    "repo": "netflow-electron"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
